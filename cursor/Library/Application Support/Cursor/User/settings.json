{
  "window.commandCenter": true,
  "workbench.colorTheme": "Default Dark Modern",
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'FiraCode Nerd Font Mono', Menlo, monospace",
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font', 'FiraCode Nerd Font Mono', Menlo, monospace",
  "editor.fontLigatures": false,
  "files.exclude": {
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*notifications/": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*plugins/": true
  },
  "files.watcherExclude": {
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*notifications/": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*plugins/": true
  },
  "files.autoSave": "onFocusChange",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "editor.tabSize": 2,
  "editor.renderWhitespace": "trailing",

  "workbench.colorCustomizations": {
    "editorWhitespace.trailingForeground": "#ff0000"
  },
  "window.autoDetectColorScheme": true,
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "git.autofetch": true,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "workbench.preferredHighContrastColorTheme": "Default Dark Modern",
  "workbench.preferredHighContrastLightColorTheme": "Default Light Modern",
  "workbench.preferredLightColorTheme": "Default Light Modern",
  "window.systemColorTheme": "dark",
  "jupyter.themeMatplotlibPlots": true,
  "markdown-preview-enhanced.mermaidTheme": "dark",
  "markdown-preview-enhanced.codeBlockTheme": "atom-dark.css",
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "redhat.telemetry.enabled": false,
  "shellcheck.customArgs": ["--external-sources"],
  "cursor.cpp.enablePartialAccepts": true,
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "githubPullRequests.pullBranch": "never",
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "workbench.preferredDarkColorTheme": "0x96f",
  "cursor.diffs.useCharacterLevelDiffs": true,
  "cursor.terminal.usePreviewBox": true,
  "markdown-preview-enhanced.previewTheme": "atom-dark.css",
  "markdown-preview-enhanced.revealjsTheme": "solarized.css",
  "markdown-preview-enhanced.previewColorScheme": "editorColorScheme",
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "datadog.connection.oauth.setup.domain": "app.datadoghq.eu",
  "aws.cloudformation.telemetry.enabled": true,
  "terminal.integrated.defaultProfile.osx": "zsh (2)",
  "terminal.integrated.scrollback": 10000,
  "cursor.composer.shouldAutoAcceptDiffs": false,
  "workbench.editor.enablePreview": false
}
