if command -v mise >/dev/null 2>&1; then
  eval "$(mise direnv activate)"
  watch_file .tool-versions .mise.toml
  if ! mise install; then
    echo "mise: install failed (advisory)" >&2
  fi
fi

# Optional: initialize Terraform plugins/providers without running terraform
# export TF_PLUGIN_CACHE_DIR="$PWD/.terraform.d/plugin-cache"
