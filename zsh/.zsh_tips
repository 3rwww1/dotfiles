_tips=(
  "tmux: prefix + c new window, prefix + n/p next/prev window"
  "tmux: prefix + z zoom current pane (toggle)"
  "tmux: prefix + , rename window"
  "tmux: prefix + x kill pane"
  "tmux: prefix + h/j/k/l navigate panes (left/down/up/right)"
  "tmux: prefix + < > + _ resize panes (left/right/up/down)"
  "tmux: prefix + Space to cycle pane layouts (swap horizontal/vertical)"
  "tmux: tmux move-window -r to renumber windows from 1"
  "tmux: Cmd+Shift+click to open URLs (Cmd+click alone is captured by mouse mode)"
  "nvim: Space+e for file tree"
  "nvim: gd go to definition, gr find references (LSP)"
  "nvim: K show hover docs, Space+ca code actions (LSP)"
  "nvim: <C-\\> for terminal"
  "nvim: Space+ff find files, Space+fg live grep (Telescope)"
  "nvim: ciw change inner word, di\" delete inside quotes"
  "nvim: % jump to matching bracket"
  "nvim: :wa save all, :qa quit all"
  "nvim: ]c / [c jump to next/prev git hunk"
  "nvim: Space+hp preview hunk, Space+hs stage, Space+hr reset"
  "nvim: Space+hb git blame for current line"
  "fzf: Ctrl+T insert file path, Ctrl+R search history, Alt+C cd into directory"
  "fzf: cmd | fzf to fuzzy-filter any output (e.g. git log --oneline | fzf)"
  "fzf: fzf --preview 'bat {}' to preview files while searching"
  "rg: rg pattern — search recursively, hidden files, with line numbers"
  "rg: rg -l pattern — list matching files only"
  "rg: rg -t py pattern — restrict to Python files (also: js, go, rb, tf...)"
  "rg: rg -C3 pattern — show 3 lines of context around matches"
  "rg: rg --glob '!vendor' pattern — exclude directories from search"
  "k: k get pods -w — watch pods in real time"
  "k: k logs -f pod-name — stream logs from a pod"
  "k: k exec -it pod-name -- sh — shell into a running pod"
  "k: k get events --sort-by=.lastTimestamp — recent cluster events"
  "k: k top pods — CPU/memory usage per pod"
  "k: k rollout restart deploy/name — rolling restart without downtime"
  "k: k config get-contexts — list available clusters/contexts"
  "k: kns namespace — switch namespace (alias for kubectl config set-context)"
  "k: k9s — TUI dashboard for Kubernetes (press : to switch resources)"
)
figlet -f small "TIP OF THE SHELL" | lolcat -f
print -P "%F{178}💡 ${_tips[RANDOM % ${#_tips[@]} + 1]}%f"
